# Flowboard desktop — configuration
#
# Rename this file to ".env" and keep it NEXT TO Flowboard.exe.
# Flowboard loads it on startup. Lines starting with # are comments.

# ── REQUIRED ──────────────────────────────────────────────────────────────
# Your Avis API key (powers Seedance 2.0 video generation). Each person who
# runs this app must supply their OWN key — do not share one.
AVIS_API_KEY=paste-your-avis-key-here

# ── OPTIONAL ──────────────────────────────────────────────────────────────
# Port the local UI listens on (default 8101). Change if it's taken.
# FLOWBOARD_HTTP_PORT=8101

# Default video model. Bundled build already defaults to Seedance 2.0 (Avis).
# FLOWBOARD_DEFAULT_VIDEO_MODEL=seedance-2-0
