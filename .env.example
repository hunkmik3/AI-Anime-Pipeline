# Flowboard — server (multi-user) configuration.
#
# Copy this to ".env" at the repo root and fill the REQUIRED values:
#     cp .env.example .env && nano .env
#
# This template is committed; ".env" itself is gitignored — NEVER commit real keys.

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Shared Avis API key (server-side — powers Seedance video gen for ALL users).
AVIS_API_KEY=

# First admin account — auto-created on first boot while the DB is empty.
FLOWBOARD_ADMIN_USER=admin
FLOWBOARD_ADMIN_PASSWORD=

# Secret that signs login tokens. Generate one:  openssl rand -hex 32
# (deploy.sh fills this automatically if left blank.)
FLOWBOARD_SECRET_KEY=

# ── MULTI-USER (keep as-is) ─────────────────────────────────────────────────
FLOWBOARD_REQUIRE_AUTH=1            # require a login token on every /api call
FLOWBOARD_DISABLE_BRIDGE=1          # no Chrome-extension / Google-Flow bridge
FLOWBOARD_DEFAULT_VIDEO_MODEL=seedance-2-0

# ── OPTIONAL ────────────────────────────────────────────────────────────────
# FLOWBOARD_HTTP_PORT=8101
# FLOWBOARD_DATABASE_URL=postgresql+psycopg://flowboard:flowboard@localhost:15432/flowboard
# FLOWBOARD_STORAGE=/Users/you/flowboard/storage     # where media + cache are kept
